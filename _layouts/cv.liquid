---
layout: default
---
<style>
.cv-post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}
.cv-download-btns {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  align-items: center;
}
.cv-dl-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.3rem 0.85rem;
  border-radius: 20px;
  border: 1.5px solid var(--global-theme-color);
  color: var(--global-theme-color) !important;
  font-size: 0.72rem;
  font-weight: 600;
  text-decoration: none !important;
  transition: background 0.18s, color 0.18s;
  white-space: nowrap;
}
.cv-dl-btn:hover {
  background: var(--global-theme-color);
  color: white !important;
}
.cv-dl-btn i { font-size: 0.7rem; }
</style>

<div class="post">
  <header class="cv-post-header">
    <h1 class="post-title" style="margin: 0;">{{ page.title }}</h1>
    <div class="cv-download-btns">
      {% if page.detailed_cv_pdf %}
        {% assign detailed_url = page.detailed_cv_pdf | prepend: 'assets/pdf/' | relative_url %}
        <button onclick="switchCV('detailed', this)" class="cv-dl-btn" style="cursor:pointer; background:var(--global-theme-color); color:white !important;">
          <i class="fas fa-file-alt"></i> Detailed CV
        </button>
      {% endif %}
      {% if page.cv_pdf %}
        <button onclick="switchCV('short', this)" class="cv-dl-btn" style="cursor:pointer;">
          <i class="fas fa-file-alt"></i> 2-Page CV
        </button>
      {% endif %}
    </div>
  </header>
  {% if page.description %}
    <p class="post-description">{{ page.description }}</p>
  {% endif %}

  <!-- PDF toggle + viewer -->
  {% if page.detailed_cv_pdf or page.cv_pdf %}
    {% assign detailed_url = page.detailed_cv_pdf | prepend: 'assets/pdf/' | relative_url %}

    <style>
      .cv-embed-wrap {
        width: 100%;
        border: 1px solid var(--global-divider-color);
        border-radius: 4px;
        overflow: auto;
        -webkit-overflow-scrolling: touch;
        height: 900px;
      }
      .cv-embed-wrap iframe {
        display: block;
        border: none;
        width: 100%;
        height: 100%;
        min-height: 900px;
      }
      @media (max-width: 768px) {
        .cv-embed-wrap { height: 75vh; }
        .cv-embed-wrap iframe { min-height: 75vh; }
      }
    </style>
    {% assign detailed_abs = page.detailed_cv_pdf | prepend: '/assets/pdf/' | prepend: site.url %}
    {% assign short_abs = page.cv_pdf | prepend: '/assets/pdf/' | prepend: site.url %}

    <div class="cv-embed-wrap">
      <iframe id="cv-iframe"
        src="https://docs.google.com/viewer?url={{ detailed_abs | url_encode }}&embedded=true"
        data-detailed="https://docs.google.com/viewer?url={{ detailed_abs | url_encode }}&embedded=true"
        data-short="https://docs.google.com/viewer?url={{ short_abs | url_encode }}&embedded=true"
        title="CV">
        <p>Your browser does not support embedded PDFs.
          <a href="{{ detailed_url }}" target="_blank">Click here to open the CV.</a>
        </p>
      </iframe>
    </div>

    <script>
      function switchCV(type, btn) {
        var iframe = document.getElementById('cv-iframe');
        iframe.src = iframe.dataset[type];
        document.querySelectorAll('.cv-dl-btn[onclick]').forEach(function(b) {
          b.style.background = '';
          b.style.color = '';
        });
        btn.style.background = 'var(--global-theme-color)';
        btn.style.color = 'white';
      }
    </script>
  {% endif %}
</div>
