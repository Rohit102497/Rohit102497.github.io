---
layout: default
---
<style>
.cv-post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}
.cv-download-btns {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  align-items: center;
}
.cv-dl-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.3rem 0.85rem;
  border-radius: 20px;
  border: 1.5px solid var(--global-theme-color);
  color: var(--global-theme-color) !important;
  font-size: 0.72rem;
  font-weight: 600;
  text-decoration: none !important;
  transition: background 0.18s, color 0.18s;
  white-space: nowrap;
}
.cv-dl-btn:hover {
  background: var(--global-theme-color);
  color: white !important;
}
.cv-dl-btn i { font-size: 0.7rem; }
</style>

<div class="post">
  <header class="cv-post-header">
    <h1 class="post-title" style="margin: 0;">{{ page.title }}</h1>
    <div class="cv-download-btns">
      {% if page.detailed_cv_pdf %}
        <a href="{{ page.detailed_cv_pdf | prepend: 'assets/pdf/' | relative_url }}" download class="cv-dl-btn">
          <i class="fas fa-download"></i> Detailed CV
        </a>
      {% endif %}
      {% if page.cv_pdf %}
        <a href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url }}" download class="cv-dl-btn">
          <i class="fas fa-download"></i> 2-Page CV
        </a>
      {% endif %}
    </div>
  </header>
  {% if page.description %}
    <p class="post-description">{{ page.description }}</p>
  {% endif %}

  <!-- Inline PDF viewer -->
  {% assign pdf_to_show = page.detailed_cv_pdf | default: page.cv_pdf %}
  {% if pdf_to_show %}
    <div class="cv-embed" style="width: 100%; border: 1px solid var(--global-divider-color); border-radius: 4px; overflow: hidden;">
      <iframe
        src="{{ pdf_to_show | prepend: 'assets/pdf/' | relative_url }}"
        width="100%"
        height="900px"
        style="display: block; border: none;"
        title="CV">
        <p>Your browser does not support embedded PDFs.
          <a href="{{ pdf_to_show | prepend: 'assets/pdf/' | relative_url }}" target="_blank">Click here to download the CV.</a>
        </p>
      </iframe>
    </div>
  {% endif %}
</div>
